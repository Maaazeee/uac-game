<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= t('game.title') %></title>
<script src="/js/sfx.js"></script>
<script src="/js/confetti.js"></script>
<script src="https://cdn.socket.io/4.8.3/socket.io.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
::selection{background:#a855f766;color:#fff}
::-webkit-scrollbar{width:8px}
::-webkit-scrollbar-track{background:#0f0f1a}
::-webkit-scrollbar-thumb{background:#2a2a4a;border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:#3a3a5a}
body{font-family:'Inter','Tajawal',sans-serif;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f0f1a 100%);color:#e0e0e0;min-height:100vh}
.top-bar{background:rgba(15,15,26,.95);backdrop-filter:blur(12px);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #7c3aed;position:sticky;top:0;z-index:100}
.top-left{display:flex;align-items:center;gap:24px}
.logo{display:flex;align-items:center;gap:12px;font-size:20px;font-weight:800;color:#fff}
.logo span{color:#c084fc}
.nav-links{display:flex;gap:16px;align-items:center}
.nav-links a{color:#aaa;text-decoration:none;font-size:14px;font-weight:600;transition:.2s}
.nav-links a:hover{color:#c084fc}
.lang-btn{background:none;border:1px solid #333;color:#888;padding:4px 10px;border-radius:6px;font-size:12px;cursor:pointer;transition:.2s;font-family:inherit;font-weight:600}
.lang-btn:hover{border-color:#7c3aed;color:#c084fc}
.lang-btn.active{border-color:#a855f7;color:#a855f7;background:#a855f722}
.user-info{display:flex;align-items:center;gap:10px;font-size:13px}
.user-info img{width:28px;height:28px;border-radius:50%;border:2px solid #7c3aed;transition:.2s}
.user-info img:hover{border-color:#c084fc;transform:scale(1.1)}
.user-info a{color:#f04747;text-decoration:none;font-size:12px}
.container{max-width:700px;margin:0 auto;padding:24px 16px;text-align:center;animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#a855f7,#9333ea);color:#fff;border:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;transition:.3s}
.btn:hover{transform:translateY(-1px);box-shadow:0 4px 20px #a855f744}
.btn:active{transform:translateY(0)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.btn-green{background:linear-gradient(135deg,#43b581,#369b6e)}
.btn-green:hover{box-shadow:0 4px 20px #43b58144}
.game-card{background:#16213e;border-radius:12px;padding:24px;margin-bottom:16px;border:1px solid #1e2a4a;text-align:left;transition:.3s}
.game-card:hover{border-color:#7c3aed;box-shadow:0 4px 30px #a855f722}
.game-card .label{font-size:11px;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.game-card .question{font-size:22px;font-weight:800;line-height:1.3;margin-bottom:12px;background:linear-gradient(135deg,#e0e0e0,#c084fc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.game-card input,.game-card textarea{background:#0f0f1a;border:2px solid #2a2a4a;color:#fff;padding:12px;border-radius:8px;font-size:16px;outline:none;transition:.3s;width:100%;font-family:inherit}
.game-card input:focus,.game-card textarea:focus{border-color:#a855f7;box-shadow:0 0 0 3px #a855f722}
.game-card textarea{resize:vertical;min-height:60px}
.bet-row{display:flex;gap:10px;margin:12px 0}
.bet-row input{flex:1}
.bet-row button{flex-shrink:0}
.bet-list{margin-top:20px}
.bet-item{background:#0f0f1a;border-radius:8px;padding:12px 16px;margin-bottom:6px;display:flex;align-items:center;gap:12px;border:1px solid #1e1e3a;transition:.3s}
.bet-item:hover{border-color:#7c3aed}
.bet-item .avatar{width:28px;height:28px;border-radius:50%;background:#2a2a4a;flex-shrink:0}
.bet-item .name{flex:1;font-weight:600;font-size:14px}
.bet-item .value{font-weight:900;font-size:18px;color:#c084fc;text-align:right}
.bet-item .bar-wrap{width:80px;height:4px;background:#2a2a4a;border-radius:2px;overflow:hidden;flex-shrink:0}
.bet-item .bar{height:100%;border-radius:2px;transition:width .5s}
.alert{padding:12px 16px;border-radius:8px;margin-bottom:12px;font-size:14px;animation:slideIn .3s ease}
@keyframes slideIn{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}
.alert-info{background:#a855f733;border:1px solid #a855f7;color:#d8b4fe}
.alert-success{background:#43b58133;border:1px solid #43b581;color:#6ee7b7}
.alert-error{background:#f0474733;border:1px solid #f04747;color:#fca5a5}
.answer-reveal{text-align:center;margin:20px 0;animation:popIn .4s cubic-bezier(.175,.885,.32,1.275)}
@keyframes popIn{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}
.answer-reveal .big{font-size:56px;font-weight:900;color:#ffd700;line-height:1;text-shadow:0 0 30px #ffd70044}
.answer-reveal .sub{color:#888;margin-top:8px;font-size:14px}
.timer{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px;padding:10px 16px;border-radius:8px;background:#0f0f1a;border:1px solid #2a2a4a;font-size:14px;transition:.3s}
.timer.warning{border-color:#f04747;background:#f0474711;animation:pulse 1s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.timer .count{font-weight:900;font-size:20px;color:#c084fc;min-width:60px;text-align:center}
.timer.warning{border-color:#f04747}
.timer.warning .count{color:#f04747}
.waiting{color:#888;padding:20px;text-align:center}
.spinner{width:40px;height:40px;border:3px solid #2a2a4a;border-top:3px solid #a855f7;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 12px}
@keyframes spin{to{transform:rotate(360deg)}}
.top-links{display:flex;gap:12px;justify-content:center;margin-bottom:16px;font-size:13px}
.top-links a{color:#888;text-decoration:none;font-weight:600}
.top-links a:hover{color:#c084fc}
.toast-container{position:fixed;top:80px;right:16px;z-index:999;display:flex;flex-direction:column;gap:8px;max-width:350px}
.toast{padding:12px 16px;border-radius:8px;font-size:13px;font-weight:600;animation:slideInRight .3s ease;box-shadow:0 4px 20px #00000044}
@keyframes slideInRight{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
.toast-info{background:#a855f7;color:#fff}
.toast-success{background:#43b581;color:#fff}
.toast-warning{background:#f59e0b;color:#000}
footer{text-align:center;padding:30px;color:#555;font-size:13px}
@media(max-width:500px){.bet-row{flex-direction:column}}
[dir="rtl"] .game-card{text-align:right}
[dir="rtl"] .bet-row{flex-direction:row-reverse}
[dir="rtl"] .bet-item .value{text-align:left}
</style>
</head>
<body>

<div class="top-bar">
  <div class="top-left">
    <div class="logo"><span>UAC</span></div>
    <div class="nav-links">
      <a href="/games" style="font-size:13px"><%= t('nav.back') %></a>
      <a href="?lang=fr" class="lang-btn <%= lang === 'fr' ? 'active' : '' %>">FR</a>
      <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
      <a href="?lang=ar" class="lang-btn <%= lang === 'ar' ? 'active' : '' %>">AR</a>
    </div>
  </div>
  <div class="user-info">
    <% if (locals.user) { %>
      <a href="/profile"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt=""></a>
      <a href="/profile" style="color:#e0e0e0;text-decoration:none"><span><%= user.globalName %></span></a>
      <% if (user.isAdmin) { %><span style="color:#a855f7;font-size:11px">(admin)</span><% } %>
      <a href="/logout"><%= t('nav.logout') %></a>
    <% } %>
  </div>
</div>

<div class="container">
  <div class="toast-container" id="toast-container"></div>
  <div class="top-links">
    <a href="/leaderboard">🏆 <%= t('nav.leaderboard') %></a>
  </div>

  <div id="app">
    <div v-if="loading" class="waiting">
      <div class="spinner"></div>
      <p>{{ translations.loading }}</p>
    </div>

    <div v-if="!loading && !currentRound">
      <div class="game-card" style="text-align:center;padding:40px">
        <div style="font-size:48px;margin-bottom:12px">🎯</div>
        <h2 style="margin-bottom:8px">{{ translations.waiting_title }}</h2>
        <p style="color:#888">{{ translations.waiting_desc }}</p>
      </div>
    </div>

    <div v-if="currentRound && !loading">
      <!-- Timer -->
      <div v-if="currentRound.deadline && !currentRound.revealed" class="timer" :class="{warning: remaining <= 300}">
        <span>{{ translations.time_remaining }}</span>
        <span class="count">{{ formattedTime }}</span>
      </div>
      <div v-if="currentRound.deadline && currentRound.revealed && remaining > 0" class="timer" style="border-color:#43b581">
        <span>{{ translations.time_up }}</span>
      </div>

      <!-- Question -->
      <div class="game-card">
        <div class="label">{{ translations.question_label }}</div>
        <div class="question">{{ currentRound.question }}</div>
        <img v-if="currentRound.contextImg" :src="currentRound.contextImg" style="max-width:100%;border-radius:8px;margin-top:8px">
      </div>

      <!-- Answer revealed -->
      <div v-if="currentRound.revealed && currentRound.answer !== null" class="answer-reveal">
        <div class="label" style="margin-bottom:4px">{{ translations.answer_label }}</div>
        <div class="big">{{ currentRound.answer }}</div>
        <div v-if="currentRound.reason" class="sub">{{ currentRound.reason }}</div>
        <div class="sub" style="margin-top:6px;font-size:12px;color:#888;border-top:1px solid #2a2a4a;padding-top:8px">
          ⚖️ {{ translations.tiebreaker_rule }}
        </div>
      </div>

      <!-- Bet form (only if not revealed, deadline not passed, and user hasn't bet) -->
      <div v-if="!currentRound.revealed && !userAlreadyBet" class="game-card">
        <div class="label" style="margin-bottom:8px">{{ translations.bet_label }}</div>
        <div id="error-msg" class="alert alert-error" v-if="error" style="display:none">{{ error }}</div>
        <div id="success-msg" class="alert alert-success" v-if="betSuccess" style="display:none">✅ {{ translations.bet_success }}</div>
        <div class="bet-row">
          <input type="number" id="bet-value" :placeholder="translations.bet_placeholder" min="0" step="any">
          <button class="btn btn-green" onclick="submitBet()">🚀 <%= t('game.bet_send') %></button>
        </div>
        <textarea id="bet-reason" :placeholder="translations.bet_reason_placeholder" style="margin-top:8px"></textarea>
      </div>
      <div v-if="!currentRound.revealed && userAlreadyBet" class="alert alert-info" style="text-align:center">
        ✅ {{ translations.bet_already }}
      </div>

      <!-- Bets list -->
      <div v-if="bets.length > 0" class="bet-list">
        <div class="label" style="margin-bottom:8px;text-align:center">
          {{ currentRound.revealed ? '🏆 ' + translations.results : '📊 ' + translations.waiting_bets }}
          ({{ bets.length }} {{ translations.participants }})
        </div>

        <div v-for="(b, i) in sortedBets" class="bet-item" :style="i === 0 && currentRound.revealed ? 'border-color:#43b581;background:#43b5810d' : ''">
          <img v-if="b.avatar && currentRound.revealed" :src="'https://cdn.discordapp.com/avatars/' + b.userId + '/' + b.avatar + '.png'" class="avatar">
          <div v-if="!b.avatar || !currentRound.revealed" class="avatar" style="display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px">?</div>
          <div class="name">
            {{ currentRound.revealed ? b.username : translations.anonymous }}
            <div v-if="b.reason" style="font-weight:400;font-size:12px;color:#888">{{ b.reason }}</div>
          </div>
          <div v-if="currentRound.revealed && currentRound.answer !== null" class="bar-wrap">
            <div class="bar" :style="{width: proximityPercent(b.value) + '%', background: i === 0 ? '#43b581' : '#a855f7'}"></div>
          </div>
          <div class="value">
            {{ b.value }}
            <div v-if="currentRound.revealed && currentRound.answer !== null" style="font-size:11px;color:#888;font-weight:400">
              ±{{ Math.abs(b.value - currentRound.answer) }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<footer><%= t('game.footer') %></footer>

<script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.min.js"></script>
<script>
var translations = <%- JSON.stringify(locale.game || locale) %>;
</script>
<script>
var app = new Vue({
  el: '#app',
  data: {
    currentRound: null,
    bets: [],
    loading: true,
    error: '',
    betSuccess: false,
    userAlreadyBet: false,
    translations: window.translations,
    remaining: 0,
    timerInterval: null,
    wasRevealed: false
  },
  computed: {
    sortedBets() {
      let b = [...this.bets];
      if (this.currentRound && this.currentRound.answer !== null) {
        b.sort((a, bb) => {
          const da = Math.abs(a.value - this.currentRound.answer);
          const db = Math.abs(bb.value - this.currentRound.answer);
          if (da !== db) return da - db;
          if (a.value <= this.currentRound.answer && bb.value > this.currentRound.answer) return -1;
          if (a.value > this.currentRound.answer && bb.value <= this.currentRound.answer) return 1;
          return 0;
        });
      }
      return b;
    },
    formattedTime() {
      const t = this.remaining;
      if (t <= 0) return '';
      const h = Math.floor(t / 3600);
      const m = Math.floor((t % 3600) / 60);
      const s = t % 60;
      if (h > 0) return h + this.translations.time_hours + ' ' + m + this.translations.time_minutes;
      if (m > 0) return m + this.translations.time_minutes + ' ' + s + this.translations.time_seconds;
      return s + this.translations.time_seconds;
    }
  },
  methods: {
    async loadState() {
      try {
        const res = await fetch('/api/state');
        const data = await res.json();
        this.currentRound = data.round;
        this.bets = data.bets || [];
        this.userAlreadyBet = data.userAlreadyBet || false;
        this.loading = false;
        // Detect reveal transition
        if (data.round && data.round.revealed && data.round.answer !== null && !this.wasRevealed) {
          this.wasRevealed = true;
          if (typeof playWin === 'function') playWin();
          if (typeof fireConfetti === 'function') fireConfetti(4000);
        }
        if (data.round && !data.round.revealed) this.wasRevealed = false;
        // Start timer if deadline exists
        if (data.round && data.round.deadline) {
          this.updateRemaining(data.round.deadline);
          if (!this.timerInterval) {
            this.timerInterval = setInterval(() => {
              if (this.currentRound && this.currentRound.deadline) {
                this.updateRemaining(this.currentRound.deadline);
              }
            }, 1000);
          }
        } else {
          this.remaining = 0;
          if (this.timerInterval) { clearInterval(this.timerInterval); this.timerInterval = null; }
        }
      } catch(e) { this.loading = false; }
    },
    updateRemaining(deadline) {
      var prev = this.remaining;
      this.remaining = Math.max(0, Math.floor((deadline - Date.now()) / 1000));
      // Countdown beep in last 10 seconds
      if (this.remaining > 0 && this.remaining <= 10 && this.remaining !== prev && typeof playCountdown === 'function') {
        playCountdown();
      }
      if (this.remaining <= 0) {
        // Time's up, reload to get revealed state
        setTimeout(() => this.loadState(), 500);
      }
    },
    proximityPercent(val) {
      if (!this.currentRound || this.currentRound.answer === null) return 0;
      const diff = Math.abs(val - this.currentRound.answer);
      const maxDiff = Math.max(...this.bets.map(b => Math.abs(b.value - this.currentRound.answer)));
      if (maxDiff === 0) return 100;
      return Math.max(5, 100 - (diff / maxDiff) * 100);
    }
  },
  mounted() {
    this.loadState();
    var socket = io();
    var self = this;
    socket.on('newRound', function() { self.loadState(); showToast(self.translations.new_round || 'Nouvelle question disponible !', 'info'); });
    socket.on('roundRevealed', function() { self.loadState(); showToast(self.translations.round_revealed || 'Réponses dévoilées !', 'success'); });
    socket.on('betUpdate', function() { self.loadState(); });
    // Fallback polling if socket disconnects
    setInterval(function() { this.loadState(); }.bind(this), 30000);
  },
  beforeDestroy() { if (this.timerInterval) clearInterval(this.timerInterval); }
});

function showToast(msg, type) {
  var container = document.getElementById('toast-container');
  if (!container) return;
  var el = document.createElement('div');
  el.className = 'toast toast-' + (type || 'info');
  el.textContent = msg;
  container.appendChild(el);
  setTimeout(function() { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; setTimeout(function() { el.remove(); }, 300); }, 4000);
}

async function submitBet() {
  const val = parseFloat(document.getElementById('bet-value').value);
  const reason = document.getElementById('bet-reason').value.trim();
  if (isNaN(val)) { showError(window.translations.bet_invalid || 'Entre un nombre valide'); return; }

  try {
    const res = await fetch('/api/bet', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ value: val, reason })
    });
    const data = await res.json();
    if (data.error) { showError(data.error); return; }
    document.getElementById('bet-value').value = '';
    document.getElementById('bet-reason').value = '';
    document.getElementById('bet-value').style.display = 'none';
    document.querySelector('.bet-row button').style.display = 'none';
    document.getElementById('success-msg').style.display = 'block';
    app.betSuccess = true;
    app.loadState();
  } catch(e) { showError(window.translations.bet_error || 'Erreur réseau'); }
}

function showError(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = msg;
  el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 3000);
}
</script>
</body>
</html>
