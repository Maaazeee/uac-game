<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= t('admin.title') %></title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter','Tajawal',sans-serif;background:#1a1a2e;color:#e0e0e0}
.top-bar{background:#0f0f1a;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #7c3aed;position:sticky;top:0;z-index:100}
.top-left{display:flex;align-items:center;gap:24px}
.logo{display:flex;align-items:center;gap:12px;font-size:20px;font-weight:800;color:#fff}
.logo span{color:#c084fc}
.nav-links{display:flex;gap:16px;align-items:center}
.nav-links a{color:#aaa;text-decoration:none;font-size:14px;font-weight:600;transition:.2s}
.nav-links a:hover{color:#c084fc}
.lang-btn{background:none;border:1px solid #333;color:#888;padding:4px 10px;border-radius:6px;font-size:12px;cursor:pointer;transition:.2s;font-family:inherit;font-weight:600}
.lang-btn:hover{border-color:#7c3aed;color:#c084fc}
.lang-btn.active{border-color:#a855f7;color:#a855f7;background:#a855f722}
.user-info{display:flex;align-items:center;gap:10px;font-size:13px}
.user-info img{width:28px;height:28px;border-radius:50%;border:2px solid #f04747}
.user-info a{color:#f04747;text-decoration:none;font-size:12px}
.container{max-width:800px;margin:0 auto;padding:24px 16px}
h1{font-size:22px;font-weight:900;margin-bottom:4px}
h1 span{color:#c084fc}
.sub{color:#888;font-size:13px;margin-bottom:20px}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:600px){.grid{grid-template-columns:1fr}}
.card{background:#16213e;border-radius:12px;padding:20px;border:1px solid #1e2a4a}
.card h2{font-size:15px;margin-bottom:12px;color:#c084fc}
.card label{display:block;font-size:12px;color:#888;margin-bottom:3px;text-transform:uppercase;letter-spacing:1px}
.card input,.card textarea,.card select{background:#0f0f1a;border:2px solid #2a2a4a;color:#fff;padding:10px 12px;border-radius:8px;font-size:14px;outline:none;transition:.2s;width:100%;margin-bottom:10px;font-family:inherit}
.card input:focus,.card textarea:focus,.card select:focus{border-color:#a855f7}
.card select option{background:#0f0f1a;color:#fff}
.card textarea{resize:vertical;min-height:60px}
.btn{display:inline-flex;align-items:center;gap:6px;background:#a855f7;color:#fff;border:none;padding:10px 18px;border-radius:8px;font-weight:600;font-size:13px;cursor:pointer;transition:.2s}
.btn:hover{background:#9333ea}
.btn-green{background:#43b581}
.btn-green:hover{background:#369b6e}
.btn-red{background:#f04747}
.btn-red:hover{background:#d33a3a}
.btn-outline{background:transparent;border:2px solid #a855f7;color:#a855f7}
.btn-outline:hover{background:#a855f733}
.btn-sm{padding:6px 12px;font-size:12px}
.alert{padding:10px 14px;border-radius:8px;margin-bottom:10px;font-size:13px}
.alert-success{background:#43b58122;border:1px solid #43b581;color:#6ee7b7}
.alert-error{background:#f0474722;border:1px solid #f04747;color:#fca5a5}
.history-item{background:#0f0f1a;border-radius:8px;padding:12px 14px;margin-bottom:6px;border:1px solid #1e1e3a;font-size:13px}
.history-item .q{font-weight:600;margin-bottom:2px}
.history-item .meta{color:#888;font-size:12px}
.history-item .r{color:#ffd700;font-weight:700}
footer{text-align:center;padding:30px;color:#555;font-size:13px}
</style>
</head>
<body>

<div class="top-bar">
  <div class="top-left">
    <div class="logo"><span>UAC</span></div>
    <div class="nav-links">
      <a href="/games" style="font-size:13px"><%= t('nav.back') %></a>
      <a href="?lang=fr" class="lang-btn <%= lang === 'fr' ? 'active' : '' %>">FR</a>
      <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
      <a href="?lang=ar" class="lang-btn <%= lang === 'ar' ? 'active' : '' %>">AR</a>
    </div>
  </div>
  <div class="user-info">
    <a href="/profile"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt=""></a>
    <a href="/profile" style="color:#e0e0e0;text-decoration:none"><span><%= user.globalName %></span></a>
    <a href="/logout"><%= t('nav.logout') %></a>
  </div>
</div>

<div class="container">
  <h1>⚙️ <%= t('admin.heading') %></h1>
  <p class="sub"><%= t('admin.sub') %></p>

  <div id="error" class="alert alert-error" style="display:none"></div>
  <div id="success" class="alert alert-success" style="display:none"></div>

  <div class="grid">
    <div class="card">
      <h2>🎯 <%= t('admin.new_question') %></h2>
      <label><%= t('admin.question_label') %></label>
      <textarea id="q" placeholder="<%= t('admin.question_placeholder') %>"></textarea>
      <label><%= t('admin.answer_label') %></label>
      <input type="number" id="a" placeholder="<%= t('admin.answer_placeholder') %>" step="any">
      <label><%= t('admin.reason_label') %></label>
      <textarea id="r" placeholder="<%= t('admin.reason_placeholder') %>"></textarea>
      <label><%= t('admin.image_label') %></label>
      <input type="url" id="img" placeholder="<%= t('admin.image_placeholder') %>">
      <label><%= t('admin.duration_label') %></label>
      <select id="dur">
        <option value="0"><%= t('admin.instant') %></option>
        <option value="1"><%= t('admin.hour_1') %></option>
        <option value="6"><%= t('admin.hour_6') %></option>
        <option value="12" selected><%= t('admin.hour_12') %></option>
        <option value="24"><%= t('admin.hour_24') %></option>
        <option value="48"><%= t('admin.hour_48') %></option>
      </select>
      <button class="btn btn-green" onclick="newQuestion()">📢 <%= t('admin.publish') %></button>
      <button class="btn btn-outline btn-sm" onclick="randomQuestion()" style="margin-top:4px">🎲 <%= t('admin.funny_question') %></button>
      <button class="btn btn-outline btn-sm" onclick="resetGame()" style="margin-top:4px">🔄 <%= t('admin.reset') %></button>
      <a href="/admin/questions" class="btn btn-outline btn-sm" style="display:inline-flex;margin-top:4px;text-decoration:none">📚 <%= t('admin.manage_questions') %></a>
    </div>

    <div class="card">
      <h2>📊 <%= t('admin.current_state') %></h2>
      <div id="state">
        <p style="color:#888;font-size:13px"><%= t('admin.loading') %></p>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top:16px">
    <h2>📜 <%= t('admin.history') %></h2>
    <div id="history"><p style="color:#888;font-size:13px"><%= t('admin.loading') %></p></div>
  </div>
</div>

<footer><%= t('admin.footer') %></footer>

<script>
var translations = <%- JSON.stringify(locale.admin || locale) %>;

async function api(url, opts = {}) {
  const res = await fetch(url, opts);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error || 'Erreur');
  return data;
}

function showError(msg) {
  const el = document.getElementById('error');
  el.textContent = msg; el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 4000);
}

function showSuccess(msg) {
  const el = document.getElementById('success');
  el.textContent = msg; el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 4000);
}

async function newQuestion() {
  const question = document.getElementById('q').value.trim();
  const answer = parseFloat(document.getElementById('a').value);
  const reason = document.getElementById('r').value.trim();
  const contextImg = document.getElementById('img').value.trim();
  const duration = parseInt(document.getElementById('dur').value);
  if (!question || isNaN(answer)) { showError(window.translations.question_required || 'Question et réponse requises'); return; }
  try {
    await api('/api/admin/question', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question, answer, reason, contextImg, duration })
    });
    showSuccess('✅ ' + (window.translations.published || 'Question publiée !'));
    document.getElementById('q').value = '';
    document.getElementById('a').value = '';
    document.getElementById('r').value = '';
    document.getElementById('img').value = '';
    loadState();
    loadHistory();
  } catch(e) { showError(e.message); }
}

async function randomQuestion() {
  try {
    const data = await api('/api/admin/random-question');
    document.getElementById('q').value = data.q;
    document.getElementById('a').value = data.a;
    document.getElementById('r').value = data.r;
  } catch(e) { showError(e.message); }
}

async function resetGame() {
  if (!confirm(window.translations.reset_confirm || 'Tout réinitialiser ?')) return;
  try {
    await fetch('/api/admin/question', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        question: 'Le jeu a été réinitialisé - une nouvelle question arrive bientôt !',
        answer: 0,
        reason: 'Réinitialisation',
        duration: 0
      })
    });
    showSuccess('✅ ' + (window.translations.reset_done || 'Jeu réinitialisé'));
    loadState(); loadHistory();
  } catch(e) { showError(e.message); }
}

async function revealNow() {
  try {
    await api('/api/admin/reveal', { method: 'POST' });
    showSuccess('✅ ' + (window.translations.revealed || 'Révélé !'));
    loadState(); loadHistory();
  } catch(e) { showError(e.message); }
}

async function loadState() {
  try {
    const data = await api('/api/state');
    const el = document.getElementById('state');
    if (data.round) {
      var participantsLabel = window.translations.participants || 'Participant(s)';
      var revealedLabel = window.translations.revealed || 'Révélé';
      var yesLabel = window.translations.yes || 'Oui';
      var noLabel = window.translations.no || 'Non';
      var revealBtn = '';
      if (!data.round.revealed && data.round.deadline) {
        revealBtn = '<button class="btn btn-sm" onclick="revealNow()" style="margin-top:8px">🔓 ' + (window.translations.reveal_now || 'Révéler maintenant') + '</button>';
      }
      el.innerHTML = `
        <div style="font-size:14px;font-weight:700;margin-bottom:4px">${data.round.question}</div>
        <div style="color:#888;font-size:12px">Réponse: <span style="color:#ffd700;font-weight:700">${data.round.answer !== null ? data.round.answer : '?'}</span></div>
        <div style="color:#888;font-size:12px">${participantsLabel}: ${data.bets.length}</div>
        <div style="color:#888;font-size:12px">${revealedLabel}: ${data.round.revealed ? '✅ ' + yesLabel : '❌ ' + noLabel}</div>
        ${revealBtn}
      `;
    } else {
      el.innerHTML = '<p style="color:#888">' + (window.translations.no_round || 'Aucune question en cours') + '</p>';
    }
  } catch(e) {
    document.getElementById('state').innerHTML = '<p style="color:#f04747">' + (window.translations.error || 'Erreur de chargement') + '</p>';
  }
}

async function loadHistory() {
  try {
    const data = await api('/api/admin/history');
    const el = document.getElementById('history');
    if (data.length === 0) { el.innerHTML = '<p style="color:#888">' + (window.translations.history_empty || 'Aucun historique') + '</p>'; return; }
    el.innerHTML = data.map(r => `
      <div class="history-item">
        <div class="q">${r.question}</div>
        <div class="meta">Réponse: <span class="r">${r.answer}</span> · ${(r.bets || []).length} participant(s) · par ${r.createdBy || 'admin'}${r.deadline ? ' · ⏱ ' + Math.round((r.deadline - Date.now()) / 3600000) + 'h' : ''}</div>
      </div>
    `).join('');
  } catch(e) {
    document.getElementById('history').innerHTML = '<p style="color:#f04747">' + (window.translations.error || 'Erreur') + '</p>';
  }
}

loadState(); loadHistory();
setInterval(loadState, 5000);
</script>
</body>
</html>
