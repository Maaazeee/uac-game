<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mes Jeux - UAC</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:#1a1a2e;color:#e0e0e0;min-height:100vh}
.top-bar{background:#0f0f1a;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #7c3aed;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:12px;font-size:20px;font-weight:800;color:#fff}
.logo span{color:#c084fc}
.logo small{font-size:12px;font-weight:400;color:#888;margin-left:8px}
.user-info{display:flex;align-items:center;gap:10px;font-size:13px}
.user-info img{width:28px;height:28px;border-radius:50%;border:2px solid #7c3aed}
.user-info a{color:#f04747;text-decoration:none;font-size:12px}
.container{max-width:600px;margin:0 auto;padding:32px 16px}
h1{font-size:24px;font-weight:900;margin-bottom:4px}
.sub{color:#888;font-size:14px;margin-bottom:24px}
.game-card{background:#16213e;border-radius:12px;padding:24px;border:1px solid #1e2a4a;display:flex;align-items:center;gap:16px;cursor:pointer;transition:.2s;margin-bottom:12px;text-decoration:none;color:inherit}
.game-card:hover{background:#1a2550;border-color:#7c3aed;transform:translateY(-2px)}
.game-card .icon{font-size:40px;flex-shrink:0}
.game-card .info{flex:1}
.game-card .info h2{font-size:18px;font-weight:700;margin-bottom:2px}
.game-card .info p{font-size:13px;color:#888}
.game-card .arrow{font-size:20px;color:#555}
.admin-card{border-color:#7c3aed;background:#1e1040}
.admin-card:hover{background:#2a1060}
footer{text-align:center;padding:24px;color:#555;font-size:13px}
</style>
</head>
<body>

<div class="top-bar">
  <div class="logo"><span>UAC</span> <small>Underground Algerian Community</small></div>
  <div class="user-info">
    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="">
    <span><%= user.globalName %></span>
    <a href="/logout">Déconnexion</a>
  </div>
</div>

<div class="container">
  <h1>🎮 Mes Jeux</h1>
  <p class="sub">Bienvenue <%= user.globalName %> ! Choisis un jeu.</p>

  <a href="/game" class="game-card">
    <div class="icon">🎯</div>
    <div class="info">
      <h2>Le Prix est Juste</h2>
      <p>Devine le nombre le plus proche de la réponse et gagne !</p>
    </div>
    <div class="arrow">→</div>
  </a>

  <% if (user.isAdmin) { %>
    <a href="/admin" class="game-card admin-card">
      <div class="icon">⚙️</div>
      <div class="info">
        <h2>Panneau Admin</h2>
        <p>Configurer les questions, gérer les manches</p>
      </div>
      <div class="arrow">→</div>
    </a>
  <% } %>
</div>

<footer>UAC — Underground Algerian Community</footer>

</body>
</html>
