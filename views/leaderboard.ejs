<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= t('leaderboard.title') %></title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter','Tajawal',sans-serif;background:#1a1a2e;color:#e0e0e0;min-height:100vh}
.top-bar{background:#0f0f1a;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #7c3aed;position:sticky;top:0;z-index:100}
.top-left{display:flex;align-items:center;gap:24px}
.logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:800;color:#fff}
.logo svg{width:28px;height:28px}
.logo span{color:#c084fc}
.nav-links{display:flex;gap:16px;align-items:center}
.nav-links a{color:#aaa;text-decoration:none;font-size:14px;font-weight:600;transition:.2s}
.nav-links a:hover{color:#c084fc}
.lang-btn{background:none;border:1px solid #333;color:#888;padding:4px 10px;border-radius:6px;font-size:12px;cursor:pointer;transition:.2s;font-family:inherit;font-weight:600}
.lang-btn:hover{border-color:#7c3aed;color:#c084fc}
.lang-btn.active{border-color:#a855f7;color:#a855f7;background:#a855f722}
.user-info{display:flex;align-items:center;gap:10px;font-size:13px}
.user-info img{width:28px;height:28px;border-radius:50%;border:2px solid #7c3aed}
.user-info a{color:#f04747;text-decoration:none;font-size:12px}
.container{max-width:600px;margin:0 auto;padding:32px 16px}
h1{font-size:24px;font-weight:900;margin-bottom:4px}
.sub{color:#888;font-size:14px;margin-bottom:24px}
.leaderboard{list-style:none}
.lb-item{background:#16213e;border-radius:10px;padding:12px 16px;margin-bottom:6px;display:flex;align-items:center;gap:12px;border:1px solid #1e2a4a;transition:.2s}
.lb-item:hover{border-color:#7c3aed}
.lb-item .rank{width:32px;height:32px;border-radius:50%;background:#0f0f1a;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;flex-shrink:0;color:#888}
.lb-item .rank.gold{background:#ffd70022;border:2px solid #ffd700;color:#ffd700}
.lb-item .rank.silver{background:#c0c0c022;border:2px solid #c0c0c0;color:#c0c0c0}
.lb-item .rank.bronze{background:#cd7f3222;border:2px solid #cd7f32;color:#cd7f32}
.lb-item .avatar{width:32px;height:32px;border-radius:50%;background:#2a2a4a;flex-shrink:0}
.lb-item .name{flex:1;font-weight:600;font-size:14px}
.lb-item .stats{text-align:right;font-size:12px;color:#888;flex-shrink:0}
.lb-item .stats strong{display:block;font-size:18px;color:#c084fc;font-weight:900}
.empty{text-align:center;color:#888;padding:40px;font-size:14px;line-height:1.6}
.loading{text-align:center;color:#888;padding:40px}
.spinner{width:32px;height:32px;border:3px solid #2a2a4a;border-top:3px solid #a855f7;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 12px}
@keyframes spin{to{transform:rotate(360deg)}}
footer{text-align:center;padding:24px;color:#555;font-size:13px}
[dir="rtl"] .lb-item .stats{text-align:left}
</style>
</head>
<body>

<div class="top-bar">
  <div class="top-left">
    <div class="logo">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
      <span>UAC</span>
    </div>
    <div class="nav-links">
      <a href="/games"><%= t('nav.games') %></a>
      <a href="?lang=fr" class="lang-btn <%= lang === 'fr' ? 'active' : '' %>">FR</a>
      <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
      <a href="?lang=ar" class="lang-btn <%= lang === 'ar' ? 'active' : '' %>">AR</a>
    </div>
  </div>
  <div class="user-info">
    <a href="/profile"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt=""></a>
    <a href="/profile" style="color:#e0e0e0;text-decoration:none"><span><%= user.globalName %></span></a>
    <a href="/logout"><%= t('nav.logout') %></a>
  </div>
</div>

<div class="container">
  <h1>🏆 <%= t('leaderboard.heading') %></h1>
  <p class="sub"><%= t('leaderboard.sub') %></p>

  <div id="app">
    <div v-if="loading" class="loading">
      <div class="spinner"></div>
      <p><%= t('game.loading') %></p>
    </div>
    <div v-else-if="entries.length === 0" class="empty">
      <div style="font-size:48px;margin-bottom:12px">🏆</div>
      <p><%= t('leaderboard.empty') %></p>
    </div>
    <div v-else class="leaderboard">
      <div v-for="(e, i) in entries" class="lb-item">
        <div class="rank" :class="{gold:i===0,silver:i===1,bronze:i===2}">{{ i + 1 }}</div>
        <img v-if="e.avatar" :src="'https://cdn.discordapp.com/avatars/' + e.userId + '/' + e.avatar + '.png'" class="avatar">
        <div v-else class="avatar" style="display:flex;align-items:center;justify-content:center;font-size:14px">?</div>
        <div class="name">{{ e.username }}</div>
        <div class="stats">
          <strong>{{ e.points }}</strong>
          <span><%= t('leaderboard.points') %></span>
          <div style="color:#888;font-size:11px;margin-top:2px">
            {{ e.wins }} <%= t('leaderboard.wins') %> · {{ e.bets }} <%= t('leaderboard.bets') %>
            <div v-if="e.impostorGames > 0" style="color:#888;font-size:11px;margin-top:1px">
              🕵️ {{ e.impostorGames }} · 🏆 {{ e.impostorWins }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<footer>UAC — Underground Algerian Community</footer>

<script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.min.js"></script>
<script>
new Vue({
  el: '#app',
  data: { entries: [], loading: true },
  mounted() { this.load(); },
  methods: {
    async load() {
      try {
        const res = await fetch('/api/leaderboard');
        this.entries = await res.json();
      } catch(e) {}
      this.loading = false;
    }
  }
});
</script>
</body>
</html>
