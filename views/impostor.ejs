<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<title><%= t('impostor.title') %></title>
<script src="/js/sfx.js"></script>
<script src="/js/confetti.js"></script>
<script src="https://cdn.socket.io/4.8.3/socket.io.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
::selection{background:#a855f766;color:#fff}
::-webkit-scrollbar{width:8px}
::-webkit-scrollbar-track{background:#0f0f1a}
::-webkit-scrollbar-thumb{background:#2a2a4a;border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:#3a3a5a}
body{font-family:'Inter','Tajawal',sans-serif;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f0f1a 100%);color:#e0e0e0;min-height:100vh}
.top-bar{background:rgba(15,15,26,.95);backdrop-filter:blur(12px);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #7c3aed;position:sticky;top:0;z-index:100}
.top-left{display:flex;align-items:center;gap:24px}
.logo{font-size:20px;font-weight:800;color:#fff}
.logo span{color:#c084fc}
.nav-links{display:flex;gap:16px;align-items:center}
.nav-links a{color:#aaa;text-decoration:none;font-size:14px;font-weight:600;transition:.2s}
.nav-links a:hover{color:#c084fc}
.lang-btn{background:none;border:1px solid #333;color:#888;padding:4px 10px;border-radius:6px;font-size:12px;cursor:pointer;transition:.2s;font-family:inherit;font-weight:600}
.lang-btn:hover{border-color:#7c3aed;color:#c084fc}
.lang-btn.active{border-color:#a855f7;color:#a855f7;background:#a855f722}
.user-info{display:flex;align-items:center;gap:10px;font-size:13px}
.user-info img{width:28px;height:28px;border-radius:50%;border:2px solid #7c3aed;transition:.2s}
.user-info img:hover{border-color:#c084fc;transform:scale(1.1)}
.user-info a{color:#f04747;text-decoration:none;font-size:12px}
.container{max-width:650px;margin:0 auto;padding:24px 16px;text-align:center;animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.phase-badge{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:700;display:inline-block;margin-bottom:12px}
.phase-submission{background:#a855f722;border:1px solid #a855f7;color:#c084fc}
.phase-voting{background:#f59e0b22;border:1px solid #f59e0b;color:#fbbf24}
.phase-revealed{background:#43b58122;border:1px solid #43b581;color:#6ee7b7}
h1{font-size:22px;font-weight:900;margin-bottom:4px}
.sub{color:#888;font-size:14px;margin-bottom:20px}
.card{background:#16213e;border-radius:12px;padding:24px;margin-bottom:14px;border:1px solid #1e2a4a;text-align:left;transition:.3s}
.card:hover{border-color:#7c3aed;box-shadow:0 4px 20px #a855f711}
.card h2{font-size:16px;font-weight:700;margin-bottom:8px;color:#c084fc}
.word-display{background:#0f0f1a;border:2px solid #7c3aed;border-radius:12px;padding:20px;text-align:center;margin:12px 0}
.word-display .word{font-size:36px;font-weight:900;color:#c084fc;letter-spacing:2px}
.word-display .hint{font-size:13px;color:#888;margin-top:6px}
.btn{display:inline-flex;align-items:center;gap:6px;background:#a855f7;color:#fff;border:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;transition:.2s;font-family:inherit}
.btn:hover{background:#9333ea}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-green{background:#43b581}
.btn-green:hover{background:#369b6e}
.btn-red{background:#f04747}
.btn-red:hover{background:#d33a3a}
.btn-sm{padding:6px 12px;font-size:12px}
.input-field{background:#0f0f1a;border:2px solid #2a2a4a;color:#fff;padding:12px;border-radius:8px;font-size:16px;outline:none;width:100%;font-family:inherit;transition:.2s;text-align:center}
.input-field:focus{border-color:#a855f7}
.player-list{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:12px 0}
.player-chip{background:#0f0f1a;border:1px solid #2a2a4a;border-radius:20px;padding:6px 14px;font-size:13px;display:flex;align-items:center;gap:6px}
.player-chip .dot{width:8px;height:8px;border-radius:50%;background:#888}
.player-chip .dot.submitted{background:#43b581}
.player-chip .dot.voted{background:#f59e0b}
.player-chip .dot.self{border:2px solid #a855f7}
.submission-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;margin:12px 0}
.submission-card{background:#0f0f1a;border:1px solid #1e1e3a;border-radius:8px;padding:12px;text-align:center}
.submission-card .sub-word{font-size:18px;font-weight:800;color:#c084fc}
.vote-card{background:#0f0f1a;border:1px solid #1e1e3a;border-radius:10px;padding:14px;cursor:pointer;transition:.2s;text-align:center}
.vote-card:hover{border-color:#a855f7;background:#1a1a3e}
.vote-card.selected{border-color:#43b581;background:#43b5810d}
.vote-card .name{font-weight:600;font-size:14px}
.vote-card .sub-word{font-size:16px;font-weight:800;color:#c084fc;margin-top:4px}
.alert{padding:12px 16px;border-radius:8px;margin-bottom:12px;font-size:14px}
.alert-info{background:#a855f733;border:1px solid #a855f7;color:#d8b4fe}
.alert-success{background:#43b58133;border:1px solid #43b581;color:#6ee7b7}
.alert-error{background:#f0474733;border:1px solid #f04747;color:#fca5a5}
.alert-warning{background:#f59e0b22;border:1px solid #f59e0b;color:#fbbf24}
.result-box{background:#0f0f1a;border-radius:12px;padding:20px;text-align:center;margin:12px 0}
.result-box .big{font-size:32px;font-weight:900;margin-bottom:4px;animation:revealPop .6s cubic-bezier(.175,.885,.32,1.275)}
@keyframes revealPop{0%{opacity:0;transform:scale(.3) rotate(-10deg)}50%{transform:scale(1.1) rotate(2deg)}100%{opacity:1;transform:scale(1) rotate(0)}}
.result-box .impostor{color:#f04747}
.result-box .winner{color:#43b581}
.result-box .label{color:#888;font-size:13px}
.waiting{color:#888;padding:20px;text-align:center}
.spinner{width:36px;height:36px;border:3px solid #2a2a4a;border-top:3px solid #a855f7;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 10px}
@keyframes spin{to{transform:rotate(360deg)}}
.top-links{display:flex;gap:12px;justify-content:center;margin-bottom:16px;font-size:13px}
.top-links a{color:#888;text-decoration:none;font-weight:600}
.top-links a:hover{color:#c084fc}
.timer{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px;padding:10px 16px;border-radius:8px;background:#0f0f1a;border:1px solid #2a2a4a;font-size:14px;transition:.3s}
.timer.warning{border-color:#f04747;background:#f0474711;animation:pulse 1s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.timer .count{font-weight:900;font-size:20px;color:#c084fc;min-width:60px;text-align:center}
.timer.warning .count{color:#f04747}
footer{text-align:center;padding:30px;color:#555;font-size:13px}
  [dir="rtl"] .card{text-align:right}
.toast-container{position:fixed;top:80px;right:16px;z-index:999;display:flex;flex-direction:column;gap:8px;max-width:350px}
.toast{padding:12px 16px;border-radius:8px;font-size:13px;font-weight:600;animation:slideInRight .3s ease;box-shadow:0 4px 20px #00000044}
@keyframes slideInRight{from{opacity:0;transform:translateX(100px)}to{opacity:1;transform:translateX(0)}}
.toast-info{background:#a855f7;color:#fff}
.toast-success{background:#43b581;color:#fff}
.toast-warning{background:#f59e0b;color:#000}
</style>
</head>
<body>

<div class="top-bar">
  <div class="top-left">
    <div class="logo"><span>UAC</span> Imposteur</div>
    <div class="nav-links">
      <a href="/games" style="font-size:13px"><%= t('nav.back') %></a>
      <a href="?lang=fr" class="lang-btn <%= lang === 'fr' ? 'active' : '' %>">FR</a>
      <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
      <a href="?lang=ar" class="lang-btn <%= lang === 'ar' ? 'active' : '' %>">AR</a>
      <button class="lang-btn" id="mute-btn" onclick="toggleMute()" style="font-size:14px">🔊</button>
    </div>
  </div>
  <div class="user-info">
    <% if (locals.user) { %>
      <a href="/profile"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt=""></a>
      <a href="/profile" style="color:#e0e0e0;text-decoration:none"><span><%= user.globalName %></span></a>
      <% if (user.isAdmin) { %><span style="color:#a855f7;font-size:11px">(admin)</span><% } %>
      <a href="/logout"><%= t('nav.logout') %></a>
    <% } %>
  </div>
</div>

<div class="container">
  <div class="toast-container" id="toast-container"></div>
  <div class="top-links">
    <a href="/leaderboard">🏆 <%= t('nav.leaderboard') %></a>
  </div>

    <div id="app">
      <div v-if="loading" class="waiting">
        <div class="spinner"></div>
        <p>{{ translations.loading }}</p>
      </div>

      <!-- No active round -->
      <div v-if="!loading && !round">
        <div class="card" style="text-align:center;padding:40px">
          <div style="font-size:48px;margin-bottom:12px">🕵️</div>
          <h2>{{ translations.waiting_title }}</h2>
          <p style="color:#888;margin-top:8px">{{ translations.waiting_desc }}</p>
        </div>
      </div>

      <!-- Active round -->
      <div v-if="round && !loading">
        <!-- Timer -->
        <div v-if="round.deadline && round.phase !== 'revealed'" class="timer" :class="{warning: remaining <= 60}">
          <span>{{ translations.time_remaining }}</span>
          <span class="count">{{ formattedTime }}</span>
        </div>

        <div class="phase-badge" :class="'phase-' + round.phase">
          {{ phaseLabel }}
        </div>

        <div class="card" v-if="round.phase === 'submission'">
          <h2>{{ translations.your_word }}</h2>
          <div class="word-display">
            <div class="word">{{ round.realWord }}</div>
            <div class="hint">{{ translations.word_hint }}</div>
          </div>
          <div style="margin-top:14px">
            <div v-if="!submitted" style="display:flex;gap:8px">
              <input class="input-field" v-model="myWord" :placeholder="translations.word_placeholder" @keyup.enter="submitWord">
              <button class="btn btn-green" @click="submitWord" :disabled="!myWord.trim()">{{ translations.submit }}</button>
            </div>
            <div v-else class="alert alert-success">✅ {{ translations.submitted }}</div>
          </div>
        </div>

        <div class="card" v-if="round.phase === 'voting'">
          <h2>{{ translations.submissions }}</h2>
          <p style="color:#888;font-size:13px;margin-bottom:12px">{{ translations.vote_hint }}</p>
          <div v-if="!voted" class="submission-grid">
            <div v-for="s in round.submissions" class="vote-card" :class="{selected: selectedVote === s.userId}" :key="s.userId" @click="selectedVote = s.userId">
              <div class="sub-word">{{ s.word }}</div>
              <div class="name" style="margin-top:4px;color:#888;font-size:12px">{{ getPlayerName(s.userId) }}</div>
            </div>
          </div>
          <div v-else class="alert alert-info">✅ {{ translations.voted }}</div>
          <button v-if="!voted && selectedVote" class="btn" @click="castVote" style="margin-top:10px;width:100%">{{ translations.vote_btn }}</button>
        </div>

        <div class="card" v-if="round.phase === 'revealed'">
          <div class="result-box">
            <div class="label">{{ translations.result }}</div>
            <div class="big" :class="round.winner === 'players' ? 'winner' : 'impostor'">
              {{ round.winner === 'players' ? '🎉 ' + translations.players_win : '😈 ' + translations.impostor_wins }}
            </div>
          </div>

          <div class="word-display" style="margin:12px 0">
            <div style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap">
              <div><span class="label" style="color:#888;font-size:12px">{{ translations.real_word }}:</span> <strong style="color:#43b581">{{ round.realWord || '?' }}</strong></div>
              <div><span class="label" style="color:#888;font-size:12px">{{ translations.fake_word }}:</span> <strong style="color:#f04747">{{ round.fakeWord || '?' }}</strong></div>
            </div>
          </div>

          <div v-if="round.submissions" style="margin-top:12px">
            <div class="label" style="text-align:center;margin-bottom:8px;color:#888">{{ translations.submissions }}</div>
            <div class="submission-grid">
              <div v-for="s in round.submissions" class="submission-card" :key="s.userId">
                <div class="sub-word">{{ s.word }}</div>
                <div style="font-size:11px;color:#888;margin-top:2px">{{ getPlayerName(s.userId) }}</div>
              </div>
            </div>
          </div>

          <div v-if="round.votes" style="margin-top:12px">
            <div class="label" style="text-align:center;margin-bottom:8px;color:#888">{{ translations.votes }}</div>
            <div v-for="(count, votedId) in round.votes" style="background:#0f0f1a;border-radius:8px;padding:8px 12px;margin-bottom:4px;display:flex;justify-content:space-between;font-size:13px">
              <span>{{ getPlayerName(votedId) }}</span>
              <span style="font-weight:700;color:#c084fc">{{ count }}</span>
            </div>
          </div>
        </div>

        <!-- Player list -->
        <div class="card" v-if="round.phase !== 'revealed'" style="text-align:center">
          <div class="label" style="color:#888;font-size:12px;margin-bottom:8px">{{ translations.players }} ({{ round.playerCount }})</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center">
            <span v-for="p in round.players" class="player-chip" :class="p.userId === userId ? 'self' : ''">
              <span class="dot" :class="playerStatus(p.userId)"></span>
              {{ p.username }}
            </span>
          </div>
        </div>
      </div>
    </div>
</div>

<footer><%= t('impostor.footer') %></footer>

<script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.min.js"></script>
<script>
var translations = <%- JSON.stringify(locale.impostor || locale) %>;
</script>
<script>
var userId = '<%= user.id %>';
var phaseNames = {
  submission: '<%= t("impostor.phase_submission") %>',
  voting: '<%= t("impostor.phase_voting") %>',
  revealed: '<%= t("impostor.phase_revealed") %>'
};

var app = new Vue({
  el: '#app',
  data: {
    round: null,
    iAmImpostor: false,
    submitted: false,
    voted: false,
    loading: true,
    myWord: '',
    selectedVote: null,
    translations: window.translations,
    userId: userId,
    wasRevealed: false,
    remaining: 0,
    timerInterval: null,
    wasNotRevealed: false
  },
  computed: {
    phaseLabel() {
      return phaseNames[this.round?.phase] || '';
    },
    formattedTime() {
      const t = this.remaining;
      if (t <= 0) return '';
      const h = Math.floor(t / 3600);
      const m = Math.floor((t % 3600) / 60);
      const s = t % 60;
      if (h > 0) return h + 'h ' + m + 'm ' + s + 's';
      if (m > 0) return m + 'm ' + s + 's';
      return s + 's';
    }
  },
  methods: {
    async fetchState() {
      try {
        await fetch('/api/impostor/join', { method: 'POST' });
        var res = await fetch('/api/impostor/state');
        var data = await res.json();
        this.round = data.round;
        this.iAmImpostor = data.iAmImpostor;
        this.submitted = data.iSubmitted;
        this.voted = data.iVoted;
        this.loading = false;
        // Dynamic title
        this.updateTitle(data);
        // Detect reveal transition
        if (data.round && data.round.phase === 'revealed' && !this.wasRevealed) {
          this.wasRevealed = true;
          if (typeof playImpostorReveal === 'function') playImpostorReveal();
          if (typeof fireConfetti === 'function') fireConfetti(4000);
          if (typeof Notification !== 'undefined' && Notification.permission === 'granted' && document.hidden) {
            new Notification(translations.result || 'Résultats !', { body: data.round.winner === 'players' ? (translations.players_win || 'Les joueurs gagnent') : (translations.impostor_wins || 'Imposteur gagne') });
          }
        }
        if (data.round && data.round.phase !== 'revealed') {
          this.wasRevealed = false;
          if (!this.wasNotRevealed) this.wasNotRevealed = true;
        }
        if (!data.round || data.round.phase === 'revealed') this.wasNotRevealed = false;
        // Start timer if deadline exists
        if (data.round && data.round.deadline && data.round.phase !== 'revealed') {
          this.updateRemaining(data.round.deadline);
          if (!this.timerInterval) {
            this.timerInterval = setInterval(function() {
              if (this.round && this.round.deadline && this.round.phase !== 'revealed') {
                this.updateRemaining(this.round.deadline);
              }
            }.bind(this), 1000);
          }
        } else {
          this.remaining = 0;
          if (this.timerInterval) { clearInterval(this.timerInterval); this.timerInterval = null; }
        }
      } catch(e) { this.loading = false; }
    },
    updateRemaining(deadline) {
      this.remaining = Math.max(0, Math.floor((deadline - Date.now()) / 1000));
      if (this.remaining <= 0) {
        setTimeout(function() { this.fetchState(); }.bind(this), 500);
      }
    },
    async submitWord() {
      if (!this.myWord.trim()) return;
      try {
        var res = await fetch('/api/impostor/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ word: this.myWord.trim() })
        });
        var data = await res.json();
        if (data.error) { alert(data.error); return; }
        this.submitted = true;
        this.myWord = '';
        this.fetchState();
      } catch(e) { alert('Erreur'); }
    },
    async castVote() {
      if (!this.selectedVote) return;
      try {
        var res = await fetch('/api/impostor/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetId: this.selectedVote })
        });
        var data = await res.json();
        if (data.error) { alert(data.error); return; }
        this.voted = true;
        this.selectedVote = null;
        this.fetchState();
      } catch(e) { alert('Erreur'); }
    },
    getPlayerName(id) {
      if (!this.round || !this.round.players) return 'Joueur ' + id.slice(0,4);
      var p = this.round.players.find(function(p) { return p.userId === id; });
      return p ? p.username : 'Joueur ' + id.slice(0,4);
    },
    playerStatus(id) {
      if (id === this.userId) return 'self';
      if (!this.round || !this.round.submissions) return '';
      var sub = this.round.submissions.find(function(s) { return s.userId === id; });
      return sub ? 'submitted' : '';
    },
    updateTitle(data) {
      var t = 'UAC Imposteur';
      if (data.round) {
        if (data.round.phase === 'revealed') t = '🔓 ' + t;
        else if (data.round.phase === 'voting') t = '🗳️ ' + t;
        else t = '✍️ ' + t;
      }
      document.title = t;
    }
  },
  mounted() {
    this.fetchState();
    if (typeof Notification !== 'undefined' && Notification.permission === 'default') Notification.requestPermission();
    var socket = io();
    var self = this;
    socket.emit('register', '<%= user.id %>');
    socket.on('impostorStateUpdate', function() { self.fetchState(); });
    socket.on('impostorStart', function() { self.fetchState(); });
    socket.on('impostorAssign', function() { self.fetchState(); });
    socket.on('impostorVoting', function() { self.fetchState(); if (typeof playImpostorVoting === 'function') playImpostorVoting(); });
    socket.on('impostorRevealed', function() { self.fetchState(); });
    socket.on('impostorPlayerJoined', function() { self.fetchState(); });
    socket.on('impostorWordSubmitted', function() { self.fetchState(); if (typeof playBet === 'function') playBet(); });
    socket.on('impostorVoteCast', function() { self.fetchState(); if (typeof playVote === 'function') playVote(); });
    socket.on('badgeUnlocked', function(data) {
      if (data.badges && data.badges.length) {
        showToast('🏆 ' + (translations.badge_unlocked || 'Badge débloqué') + ': ' + data.badges.join(', '), 'success');
      }
    });
    // Enter key shortcut for word submission
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && self.round && self.round.phase === 'submission' && !self.submitted && self.myWord.trim()) self.submitWord();
    });
    // Fallback polling
    setInterval(function() { this.fetchState(); }.bind(this), 30000);
    // Mute button init
    updateMuteBtn();
  },
  beforeDestroy() { if (this.timerInterval) clearInterval(this.timerInterval); }
});
function toggleMute() {
  var muted = getCookie('mute') === '1';
  document.cookie = 'mute=' + (muted ? '0' : '1') + '; path=/; max-age=' + 365*24*60*60;
  updateMuteBtn();
}
function updateMuteBtn() {
  var btn = document.getElementById('mute-btn');
  if (btn) btn.textContent = getCookie('mute') === '1' ? '🔇' : '🔊';
}
function getCookie(name) {
  var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
  return v ? v.pop() : '';
}
function showToast(msg, type) {
  var container = document.getElementById('toast-container');
  if (!container) return;
  var el = document.createElement('div');
  el.className = 'toast toast-' + (type || 'info');
  el.textContent = msg;
  container.appendChild(el);
  setTimeout(function() { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; setTimeout(function() { el.remove(); }, 300); }, 4000);
}
</script>
